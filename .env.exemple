# Portal Acadêmico (Jacad)
JACAD_URL=https://seu-portal.jacad.com.br/academico/aluno-v2/financeiro/
JACAD_USER=seu_usuario_ou_ra
JACAD_PASS=sua_senha

# Gmail (condomínio)
# Use uma App Password — nunca sua senha normal
# Como gerar: myaccount.google.com/apppasswords
GMAIL_USER=seu@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Remetente do boleto do condomínio
COND_REMETENTE=atendimento@suaadministradora.com.br

# Pasta onde os PDFs serão salvos
PASTA_SAIDA=C:/Users/SeuUsuario/Boletos
